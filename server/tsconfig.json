{
  "compilerOptions": {
    "target": "ES2023",
    // `DOM` no es porque haya navegador: aporta los tipos de Web Crypto
    // (`CryptoKey`, `crypto.subtle`), que Node implementa desde la v20.
    "lib": ["ES2023", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
